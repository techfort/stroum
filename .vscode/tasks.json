{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Current Stroum File",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/dist/cli.js",
        "run",
        "${file}"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Compile Current Stroum File",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/dist/cli.js",
        "compile",
        "${file}"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
