-- Stroum Process Module
-- Shell command execution and environment operations

f:exec cmd:String -> String => __builtin_exec(cmd)
f:exec_lines cmd:String -> Any => __builtin_exec_lines(cmd)
f:env_get name:String -> String => __builtin_env_get(name)
f:env_get_or name:String fallback:String -> String => __builtin_env_get_or(name, fallback)
f:env_keys -> Any => __builtin_env_keys()
f:cwd -> String => __builtin_cwd()
f:exit_process code:Int -> Void => __builtin_exit_process(code)
