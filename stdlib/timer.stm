-- Stroum Timer Module
-- Time, delays, and date formatting

f:sleep ms:Int -> Void => __builtin_sleep(ms)
f:now -> Float => __builtin_now()
f:timestamp -> String => __builtin_timestamp()
f:elapsed start:Float -> Float => __builtin_elapsed(start)
f:format_date ms:Float locale:String -> String => __builtin_format_date(ms, locale)
f:interval ms:Int -> Void => interval(ms)
