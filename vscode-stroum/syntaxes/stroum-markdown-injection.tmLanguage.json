{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Stroum Markdown Injection",
  "scopeName": "markdown.stroum.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "begin": "(^|\\G)(\\s*)(```|~~~)(\\s*)(stroum)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" },
        "5": { "name": "entity.name.language.stroum" }
      },
      "end": "(^|\\G)(\\2)(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.fenced.markdown" }
      },
      "contentName": "meta.embedded.block.stroum",
      "patterns": [{ "include": "source.stroum" }]
    }
  ]
}
