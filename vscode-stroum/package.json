{
  "name": "stroum",
  "displayName": "Stroum",
  "description": "Syntax highlighting and language support for Stroum programming language",
  "version": "1.1.1",
  "publisher": "stroum",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stroum/stroum"
  },
  "main": "./out/extension.js",
  "extensionKind": ["ui", "workspace"],
  "activationEvents": [
    "onLanguage:stroum",
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "stroum",
    "functional",
    "streams",
    "pipes"
  ],
  "contributes": {
    "languages": [
      {
        "id": "stroum",
        "aliases": [
          "Stroum",
          "stroum"
        ],
        "extensions": [
          ".stm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "stroum",
        "scopeName": "source.stroum",
        "path": "./syntaxes/stroum.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "stroum",
        "path": "./snippets/stroum.json"
      }
    ],
    "commands": [
      {
        "command": "stroum.showDataflowPanel",
        "title": "Show Dataflow Graph",
        "category": "Stroum",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "stroum.showDataflowPanel",
          "when": "resourceExtname == .stm",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^20.0.0",
    "cytoscape": "^3.31.0",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc && npm run build:webview",
    "build:webview": "esbuild webview-src/dataflow.ts --bundle --outfile=media/dataflow.js --format=iife --target=es2020",
    "watch": "tsc --watch"
  }
}
