{
  "name": "stroum",
  "version": "1.0.0",
  "description": "Stroum functional, pipe-first, stream-oriented programming language transpiler",
  "main": "dist/index.js",
  "bin": {
    "stroum": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/runtime-template.ts dist/ && mkdir -p dist/stdlib && cp stdlib/*.ts dist/stdlib/ && node stdlib/build-stdlib.cjs && npm run build:graph-webview",
    "build:graph-webview": "esbuild src/graph-webview.ts --bundle --outfile=dist/graph-webview.js --format=iife --target=es2020 --platform=browser",
    "test": "jest",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "ts-node src/cli.ts"
  },
  "keywords": [
    "transpiler",
    "functional",
    "streams"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/cytoscape": "^3.21.9",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "cytoscape": "^3.33.3",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "esbuild": "^0.25.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "avsc": "^5.7.7",
    "papaparse": "^5.4.1",
    "parquetjs": "^0.11.2",
    "source-map": "^0.7.4",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
