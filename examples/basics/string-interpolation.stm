-- String interpolation demo: "Hello #{expr}"
-- #{} embeds any Stroum expression directly into a string.

:name "world"
:count 3

f:main name:String count:Int x:Int -> Void =>
  println("Hello #{name}!")
  println("#{count} items processed")
  println("The value is #{x} and its double is #{mul(x, 2)}")

main(name, count, 42)
