-- Example with streams and outcomes

f:check num =>
  if gt(num, 0) then .ok num
  else .error "value is not positive"

f:save num =>
  println("Saved: #{num}")
  num

f:report_error msg =>
  println("Error: #{msg}")
  msg

f:validate num ~> @"valid", @"errors" =>
  check(num)
  | .ok    => save(num) @ "valid"
  | .error => report_error(num) @ "errors"

validate(42)
validate(sub(0, 5))

on @"valid" |> |:x| => println("OK: #{x}")
on @"errors" |> |:e| => println("Invalid: #{e}")
