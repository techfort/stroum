-- wiring.stm
-- Wires triage -> enrich using an explicit wire: declaration.
-- triage.valid feeds enrich.input; enriched output is printed.

i:"./triage.stm"
i:"./enrich.stm"

wire: @triage_valid -> @enrich_input

snk: @triage_invalid println
snk: @enrich_output  println

src: @triage_events "hello world"
src: @triage_events "error: something went wrong"

run until timeout(100)
